# Projeto Supabase "lidera+" (vqrnjiwansfobxaeswnu, org Agencia F4, sa-east-1)
NEXT_PUBLIC_SUPABASE_URL=https://vqrnjiwansfobxaeswnu.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_TpS2uoJ-2m_YuPkRSTBK3A_I-D21X4D

# OBRIGATÓRIO em produção (usado em src/app/login/actions.ts e
# configuracoes/usuarios/actions.ts para montar o link de "redefinir senha"
# e o convite de novo usuário que vai por e-mail). Sem isso o link do e-mail
# fica sem domínio e quebra. Em local dev pode ficar em branco (localhost).
# Ex.: https://lidera-plus.vercel.app ou o domínio próprio da campanha.
NEXT_PUBLIC_SITE_URL=

# Só para uso em Edge Functions / jobs de servidor (nunca no bundle do client).
# Pegue em Project Settings > API > service_role no painel do Supabase.
SUPABASE_SERVICE_ROLE_KEY=

# Mapa Territorial (Módulo 8, src/components/map/territory-map.tsx) — centro
# e zoom usados só quando não há nenhuma liderança/demanda com lat/lng
# cadastrada ainda (com pelo menos 1 pin, o mapa ajusta sozinho via
# fitBounds). Opcional: ajuste para a coordenada do município da campanha.
# Fallback se deixar em branco: centro geográfico do Brasil, zoom 12.
NEXT_PUBLIC_MAP_DEFAULT_LAT=
NEXT_PUBLIC_MAP_DEFAULT_LNG=
NEXT_PUBLIC_MAP_DEFAULT_ZOOM=
